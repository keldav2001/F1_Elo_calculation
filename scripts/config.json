{
    "api": {
        "base_url": "https://api.jolpi.ca/ergast/f1",
        "limit": 1000,
        "timeout": 10
    },
    "pipeline": {
        "start_year": 2020,
        "end_year": 2025,
        "endpoints": [
            "drivers",
            "results"
        ]
    },
    "storage": {
        "bronze_path": "../f1data-bronze",
        "silver_path": "../f1data-silver"
    }
}